--- a/system/box64.box64rc
+++ b/system/box64.box64rc
@@ -16,6 +16,33 @@
 # using safest dynarec settings here, as some installers do crazy things
 BOX64_DYNACACHE=0
 BOX64_DYNAREC_SAFEFLAGS=2
+BOX64_DYNAREC_BIGBLOCK=0
+BOX64_DYNAREC_CALLRET=0
+
+#
+# Android / Termux glibc / Wine gaming baseline
+# Keep Windows executables more compatible than the fastest profile, while still
+# enabling the major ARM64 dynarec speed paths on modern Snapdragon devices.
+# Per-game sections below or user environment variables can override these.
+#
+[*wine*]
+BOX64_DYNAREC_SAFEFLAGS=1
+BOX64_DYNAREC_STRONGMEM=1
+BOX64_DYNAREC_BIGBLOCK=2
+BOX64_DYNAREC_CALLRET=1
+BOX64_DYNAREC_ALIGNED_ATOMICS=1
+
+[*.exe]
+BOX64_DYNAREC_SAFEFLAGS=1
+BOX64_DYNAREC_STRONGMEM=1
+BOX64_DYNAREC_BIGBLOCK=2
+BOX64_DYNAREC_CALLRET=1
+BOX64_DYNAREC_ALIGNED_ATOMICS=1
+
+[*setup.exe]
+BOX64_DYNACACHE=0
+BOX64_DYNAREC_SAFEFLAGS=2
+BOX64_DYNAREC_STRONGMEM=2
 BOX64_DYNAREC_BIGBLOCK=0
 BOX64_DYNAREC_CALLRET=0
 
